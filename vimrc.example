" ============================================================================
" Fresh Vim Configuration with Genero-Tools Plugin
" ============================================================================

" ============================================================================
" Vim-Plug Setup
" ============================================================================

" Install vim-plug if not already installed
if empty(glob('~/.vim/autoload/plug.vim'))
  silent !curl -fLo ~/.vim/autoload/plug.vim --create-dirs
    \ https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
  autocmd VimEnter * PlugInstall --sync | source $MYVIMRC
endif

" Begin plugin declarations
call plug#begin('~/.vim/plugged')

" Genero-Tools Plugin - Code navigation for Genero codebases
Plug 'hdean-ssp/genero-vim'

" Optional: Add other useful plugins
" Plug 'tpope/vim-sensible'           " Sensible defaults
" Plug 'vim-airline/vim-airline'      " Status line
" Plug 'preservim/nerdtree'           " File explorer
" Plug 'junegunn/fzf.vim'             " Fuzzy finder

call plug#end()

" ============================================================================
" Basic Vim Settings
" ============================================================================

set nocompatible                " Use Vim defaults
set encoding=utf-8              " Use UTF-8 encoding
set number                      " Show line numbers
set relativenumber              " Show relative line numbers
set cursorline                  " Highlight current line
set tabstop=4                   " Tab width
set shiftwidth=4                " Indent width
set expandtab                   " Use spaces instead of tabs
set autoindent                  " Auto-indent new lines
set smartindent                 " Smart indentation
set hlsearch                    " Highlight search results
set incsearch                   " Incremental search
set ignorecase                  " Case-insensitive search
set smartcase                   " Smart case search
set mouse=a                     " Enable mouse support
set background=dark             " Dark background
set termguicolors               " True color support (if terminal supports it)

" ============================================================================
" Genero-Tools Plugin Configuration
" ============================================================================

" Configure genero-tools plugin
let g:genero_tools_config = {
  \ 'genero_tools_path': 'query.sh',           " Path to query.sh (must be in PATH)
  \ 'cache_enabled': v:true,                   " Enable result caching
  \ 'cache_ttl': 3600,                         " Cache TTL in seconds (1 hour)
  \ 'cache_max_size': 100,                     " Max cache entries
  \ 'display_mode': 'quickfix',                " Display mode: quickfix|popup|inline|split|echo
  \ 'keybindings_enabled': v:true,             " Enable default keybindings
  \ 'timeout': 10000,                          " Command timeout (ms) - 10s for large codebases
  \ 'async_enabled': v:true,                   " Show progress for long commands
  \ 'result_limit': 1000,                      " Max results before warning
  \ 'pagination_size': 50                      " Results per page
  \ }

" ============================================================================
" Genero-Tools Keybindings
" ============================================================================
" Default keybindings are automatically registered if keybindings_enabled is true
" 
" <leader>gl  - Find function under cursor
" <leader>gf  - List functions in current file
" <leader>gs  - Get function signature under cursor
" <leader>gm  - Get metadata for current file
"
" To customize, uncomment and modify below:
" nnoremap <silent> <leader>gl :GeneroLookup <C-R><C-W><CR>
" nnoremap <silent> <leader>gf :GeneroListFunctions %<CR>
" nnoremap <silent> <leader>gs :GeneroFunctionSignature <C-R><C-W><CR>
" nnoremap <silent> <leader>gm :GeneroFileMetadata %<CR>

" ============================================================================
" Genero-Tools Commands Reference
" ============================================================================
"
" :GeneroLookup [function_name]           - Find function definition
" :GeneroListFunctions [file_path]        - List functions in file
" :GeneroListModuleFiles [module_name]    - List files in module
" :GeneroFunctionSignature [function_name] - Get function signature
" :GeneroFileMetadata [file_path]         - Get file metadata
" :GeneroConfigShow                       - Display current config
" :GeneroClearCache                       - Clear result cache
"

" ============================================================================
" Display Mode Configuration
" ============================================================================
" Uncomment one of the following to change display mode:
"
" let g:genero_tools_config.display_mode = 'quickfix'  " Quickfix list (default)
" let g:genero_tools_config.display_mode = 'inline'    " Popup above cursor
" let g:genero_tools_config.display_mode = 'popup'     " Large floating window (Neovim only)
" let g:genero_tools_config.display_mode = 'split'     " New split window
" let g:genero_tools_config.display_mode = 'echo'      " Command line output
"

" ============================================================================
" Large Codebase Configuration (Optional)
" ============================================================================
" Uncomment and customize for large codebases (6M+ LOC, thousands of files):
"
" let g:genero_tools_config = {
"   \ 'genero_tools_path': 'query.sh',
"   \ 'cache_enabled': v:true,
"   \ 'cache_ttl': 7200,                         " Longer TTL
"   \ 'cache_max_size': 200,                     " Larger cache
"   \ 'display_mode': 'inline',                  " Quick inline popups
"   \ 'keybindings_enabled': v:true,
"   \ 'timeout': 15000,                          " 15 seconds
"   \ 'async_enabled': v:true,                   " Keep editor responsive
"   \ 'result_limit': 2000,                      " Allow more results
"   \ 'pagination_size': 100                     " Larger pages
"   \ }
"

" ============================================================================
" Custom Keybindings (Optional)
" ============================================================================
" Uncomment to add custom keybindings:
"
" " Map Ctrl+G to show config
" nnoremap <C-g> :GeneroConfigShow<CR>
"
" " Map Ctrl+C to clear cache
" nnoremap <C-c> :GeneroClearCache<CR>
"

" ============================================================================
" Troubleshooting
" ============================================================================
"
" If query.sh is not in PATH, set the full path:
" let g:genero_tools_config.genero_tools_path = '/path/to/query.sh'
"
" For slow queries, increase timeout:
" let g:genero_tools_config.timeout = 20000
"
" To disable keybindings:
" let g:genero_tools_config.keybindings_enabled = v:false
"
" To verify installation:
" :GeneroConfigShow
"
