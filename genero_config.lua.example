-- Genero Tools Configuration for Neovim
-- Place this in ~/.config/nvim/genero_config.lua or source it from init.lua

local M = {}

-- Compiler settings
M.compiler_enabled = true
M.compiler_autocompile = true
M.compiler_autocompile_delay = 500  -- milliseconds

-- UI settings
M.compiler_sign_column = true       -- Show error/warning signs in gutter
M.compiler_highlight_unused = true  -- Highlight unused variables

-- Compiler command and arguments
M.compiler_command = "fglcomp"
M.compiler_args = { "-M", "-W", "all" }

-- Query tool path (required for some features)
-- Set BRODIR environment variable or update this path
M.query_sh_path = (os.getenv("BRODIR") or "/opt/brodir") .. "/etc/genero-tools/query.sh"

-- Display mode for compilation results
-- Options: "quickfix" (default), "floating" (Neovim only)
M.display_mode = "quickfix"

-- Apply configuration to global genero_tools_config
if not vim.g.genero_tools_config then
  vim.g.genero_tools_config = {}
end

for key, value in pairs(M) do
  vim.g.genero_tools_config[key] = value
end

return M
