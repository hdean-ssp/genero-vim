" TEST 2: Basic Settings
set nocompatible

" UI & Display
set number
set cursorline

" Indentation & Formatting
set expandtab
set shiftwidth=2
set tabstop=2

" Search & Navigation
set ignorecase
set smartcase
set hlsearch
set incsearch

" Performance & Behavior
set updatetime=250
set timeoutlen=300
set splitbelow
set splitright

" Terminal colors
if has('termguicolors')
  set termguicolors
endif

set background=dark
