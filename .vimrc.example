" Vim Configuration for Genero Development
" Copy this to ~/.vimrc and adjust paths as needed
" This config works with both Vim 8+ and Neovim

" CRITICAL: Disable Vi compatibility mode (must be first!)
set nocompatible

" ============================================================================
" BASIC SETTINGS (MINIMAL - for arrow key compatibility)
" ============================================================================

" UI & Display
set number
set cursorline

" Indentation & Formatting
set noexpandtab
set shiftwidth=4
set tabstop=4

" Search & Navigation
set ignorecase
set smartcase
set hlsearch
set incsearch

" Performance & Behavior
set updatetime=250
set timeoutlen=300
set splitbelow
set splitright

" Terminal colors (Vim 8+ and Neovim)
if has('termguicolors')
  set termguicolors
endif

set background=dark

" ============================================================================
" VIM-PLUG INITIALIZATION
" ============================================================================

" Install vim-plug if not already installed
if empty(glob('~/.vim/autoload/plug.vim'))
  silent !curl -fLo ~/.vim/autoload/plug.vim --create-dirs
    \ https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
  autocmd VimEnter * PlugInstall --sync | source $MYVIMRC
endif

call plug#begin('~/.vim/plugged')

" Genero Tools Plugin
Plug 'hdean-ssp/genero-vim'

" LuaSnip - Code snippets (Vim 8.2+ and Neovim)
if has('nvim') || v:version >= 802
  Plug 'L3MON4D3/LuaSnip', {'tag': 'v2.*', 'do': 'make install_jsregexp || true'}
endif

" Statusline (Vim 8+ and Neovim)
if has('nvim') || v:version >= 800
  Plug 'nvim-lualine/lualine.nvim'
  Plug 'nvim-tree/nvim-web-devicons'
endif

" Which-key for keybinding hints (Neovim only)
if has('nvim')
  Plug 'folke/which-key.nvim'
endif

" Modern UI enhancements (Neovim only)
if has('nvim')
  Plug 'folke/tokyonight.nvim'
  Plug 'folke/noice.nvim'
  Plug 'MunifTanjim/nui.nvim'
  Plug 'rcarriga/nvim-notify'
  Plug 'stevearc/dressing.nvim'
  Plug 'lukas-reineke/indent-blankline.nvim'
  Plug 'numToStr/comment.nvim'
endif

call plug#end()

" ============================================================================
" GENERO TOOLS CONFIGURATION
" ============================================================================

let g:genero_tools_config = {
  \ 'compiler_enabled': 1,
  \ 'compiler_autocompile': 1,
  \ 'compiler_autocompile_delay': 500,
  \ 'compiler_sign_column': 1,
  \ 'compiler_sign_column_always_visible': 1,
  \ 'compiler_highlight_unused': 1,
  \ 'compiler_show_warnings': 1,
  \ 'compiler_show_errors': 1,
  \ 'compiler_command': 'fglcomp',
  \ 'compiler_args': ['-M', '-W', 'all'],
  \ 'compiler_form_command': 'fglform',
  \ 'compiler_form_args': ['-M', '-W', 'all'],
  \ 'compiler_source_dir': '.',
  \ 'compiler_version': 'auto',
  \ 'genero_tools_path': $BRODIR . '/etc/genero-tools/query.sh',
  \ 'display_mode': 'inline',
  \ 'snippets_enabled': 1,
  \ 'snippet_engine': 'luasnip',
  \ 'snippet_smart_expansion': 1,
  \ 'snippet_custom_dir': expand('~/.config/nvim/genero-snippets'),
  \ 'keybindings_enabled': 1,
  \ 'hints_enabled': 1,
  \ 'hints_display': 'signs',
  \ 'hints_severity': 'warning',
  \ 'hints_realtime': 1,
  \ 'hints_cache_enabled': 1,
  \ 'hints_cache_ttl': 300,
  \ 'hints_delay': 500,
  \ 'auto_fix_enabled': 1,
  \ 'trailing_whitespace': 1,
  \ 'mixed_indentation': 1,
  \ 'indentation_consistency': 1,
  \ 'multiple_blank_lines': 1,
  \ 'lowercase_keywords': 1,
  \ 'lowercase_functions': 1,
  \ 'keyword_consistency': 1,
  \ 'naming_convention': 0,
  \ 'unclosed_blocks': 1,
  \ 'nesting_depth': 1,
  \ 'line_length': 1,
  \ 'missing_comments': 0,
  \ 'missing_error_handling': 0,
  \ 'deprecated_functions': 1,
  \ 'max_line_length': 100,
  \ 'max_nesting_depth': 5,
  \ 'max_blank_lines': 2,
  \ 'naming_convention_style': 'camelCase',
  \ 'cache_enabled': 1,
  \ 'cache_ttl': 3600,
  \ 'cache_max_size': 100,
  \ 'result_limit': 1000,
  \ 'pagination_size': 50,
  \ 'codebase_markers': ['castle.sch', 'genero.conf', '.genero', '.git'],
  \ 'startup_messages': 'silent',
  \ 'timeout': 10000,
  \ 'async_enabled': 1,
  \ 'svn_enabled': 1,
  \ 'svn_show_added': 1,
  \ 'svn_show_modified': 1,
  \ 'svn_show_deleted': 1,
  \ 'svn_cache_ttl': 300,
  \ 'svn_auto_update': 1,
  \ 'floating_window_border': 'rounded',
  \ 'floating_window_width': 80,
  \ 'floating_window_height': 20,
  \ 'floating_window_position': 'center',
  \ 'floating_window_title': 'Genero-Tools',
  \ 'popup_auto_close_delay': 5000,
  \ 'debug_stream_enabled': 0,
  \ 'debug_stream_width': 0,
  \ 'debug_stream_max_lines': 1000,
  \ 'debug_stream_auto_scroll': 1,
  \ 'debug_stream_directory': './debug',
  \ 'autocomplete_on_pause': 1,
  \ 'autocomplete_delay': 500,
  \ 'debug_mode': 0,
  \ 'lua_enabled': has('nvim'),
  \ 'format_hover_enabled': 1,
  \ 'format_completion_enabled': 1,
  \ 'format_concise_enabled': 1,
  \ 'format_cache_enabled': 1,
  \ 'format_cache_ttl': 3600,
  \ 'statusline_show_function': 1,
  \ 'statusline_function_max_length': 50,
  \ 'statusline_show_diagnostics': 1,
  \ }

" Uncomment and adjust if your query.sh is in a custom location
" let g:genero_tools_config.genero_tools_path = expand('~/personal/genero-tools/query.sh')

" ============================================================================
" NEOVIM-SPECIFIC CONFIGURATION
" ============================================================================

if has('nvim')
  " Set leader key
  let mapleader = ' '
  let maplocalleader = ' '

  " Tokyonight theme
  colorscheme tokyonight

  " Lualine configuration
  lua << EOF
local lualine_genero = require('genero_tools.lualine')
lualine_genero.setup()

require('lualine').setup({
  options = {
    theme = 'tokyonight',
    component_separators = { left = '│', right = '│' },
    section_separators = { left = '', right = '' },
    globalstatus = true,
  },
  sections = {
    lualine_a = { 'mode' },
    lualine_b = { 'filename', 'modified' },
    lualine_c = { 'diagnostics', lualine_genero.diagnostics, lualine_genero.function_signature },
    lualine_x = { 'encoding', 'fileformat', 'filetype' },
    lualine_y = { 'progress' },
    lualine_z = { 'location' },
  },
  tabline = {
    lualine_a = { 'buffers' },
    lualine_z = { 'tabs' },
  },
})

require('Comment').setup({
  padding = true,
  sticky = true,
  toggler = {
    line = 'gcc',
    block = 'gbc',
  },
  opleader = {
    line = 'gc',
    block = 'gb',
  },
  extra = {
    above = 'gcO',
    below = 'gco',
    eol = 'gcA',
  },
})

require('ibl').setup({
  indent = { char = '│' },
  scope = { enabled = true },
})

local nvim_ver_setup = vim.version()
local is_010_plus_setup = nvim_ver_setup.major > 0 or nvim_ver_setup.minor >= 10

if is_010_plus_setup then
  require('which-key').setup({
    preset = 'classic',
    win = {
      border = 'rounded',
    },
  })
else
  require('which-key').setup({
    window = {
      border = 'rounded',
      position = 'bottom',
    },
  })
end
EOF

  " Which-key descriptions (version-aware)
  lua << EOF
local wk = require('which-key')
local nvim_ver = vim.version()
local is_010_plus = nvim_ver.major > 0 or nvim_ver.minor >= 10

if is_010_plus then
  -- which-key v3+ API
  wk.add({
    { '<leader>c', group = 'Compiler' },
    { '<leader>ca', ':GeneroAutocompileEnable<CR>', desc = 'Enable autocompile' },
    { '<leader>cd', ':GeneroAutocompileDisable<CR>', desc = 'Disable autocompile' },
    { '<leader>cc', ':GeneroClearErrors<CR>', desc = 'Clear errors' },

    { '<leader>h', group = 'Hints' },
    { '<leader>hn', ':GeneroNextHint<CR>', desc = 'Next hint' },
    { '<leader>hp', ':GeneroPrevHint<CR>', desc = 'Previous hint' },
    { '<leader>hl', ':GeneroListHints<CR>', desc = 'List all hints' },
    { '<leader>hd', ':GeneroHintDetails<CR>', desc = 'Hint details' },
    { '<leader>hf', ':GeneroHintAutofix<CR>', desc = 'Apply auto-fix' },

    { '<leader>s', group = 'SVN/Signs' },
    { '<leader>sv', ':GeneroSVNToggle<CR>', desc = 'Toggle SVN markers' },
    { '<leader>sr', ':GeneroSVNRefresh<CR>', desc = 'Refresh SVN markers' },
    { '<leader>ss', ':GeneroSVNStatus<CR>', desc = 'SVN status' },
    { '<leader>su', ':GeneroUnifiedSignsToggle<CR>', desc = 'Toggle unified signs' },
    { '<leader>sl', ':GeneroSnippetList<CR>', desc = 'List snippets' },
    { '<leader>sh', ':GeneroSnippetHelp<CR>', desc = 'Snippet help' },

    { '<leader>b', group = 'Buffers' },
    { '<leader>bn', ':bnext<CR>', desc = 'Next buffer' },
    { '<leader>bp', ':bprev<CR>', desc = 'Previous buffer' },
    { '<leader>bd', ':bdelete<CR>', desc = 'Delete buffer' },
  })
else
  -- which-key v1.x API
  wk.register({
    c = {
      name = '+Compiler',
      a = { ':GeneroAutocompileEnable<CR>', 'Enable autocompile' },
      d = { ':GeneroAutocompileDisable<CR>', 'Disable autocompile' },
      c = { ':GeneroClearErrors<CR>', 'Clear errors' },
    },
    h = {
      name = '+Hints',
      n = { ':GeneroNextHint<CR>', 'Next hint' },
      p = { ':GeneroPrevHint<CR>', 'Previous hint' },
      l = { ':GeneroListHints<CR>', 'List all hints' },
      d = { ':GeneroHintDetails<CR>', 'Hint details' },
      f = { ':GeneroHintAutofix<CR>', 'Apply auto-fix' },
    },
    s = {
      name = '+SVN/Signs',
      v = { ':GeneroSVNToggle<CR>', 'Toggle SVN markers' },
      r = { ':GeneroSVNRefresh<CR>', 'Refresh SVN markers' },
      s = { ':GeneroSVNStatus<CR>', 'SVN status' },
      u = { ':GeneroUnifiedSignsToggle<CR>', 'Toggle unified signs' },
    },
    sl = {
      name = '+Snippets',
      l = { ':GeneroSnippetList<CR>', 'List snippets' },
      h = { ':GeneroSnippetHelp<CR>', 'Snippet help' },
    },
    b = {
      name = '+Buffers',
      n = { ':bnext<CR>', 'Next buffer' },
      p = { ':bprev<CR>', 'Previous buffer' },
      d = { ':bdelete<CR>', 'Delete buffer' },
    },
  }, { prefix = '<leader>' })
end
EOF
endif

" ============================================================================
" KEYBINDINGS (Works in both Vim and Neovim)
" ============================================================================

" Compile current file (F5)
nnoremap <F5> :GeneroCompile<CR>

" Autocomplete (Ctrl+N in insert mode - replaces Ctrl+Space for terminal compatibility)
inoremap <C-n> <C-x><C-o>

" Navigate errors/warnings
nnoremap <C-,> :GeneroPrevError<CR>
nnoremap <C-.> :GeneroNextError<CR>

" Toggle autocompile
nnoremap <leader>ca :GeneroAutocompileEnable<CR>
nnoremap <leader>cd :GeneroAutocompileDisable<CR>

" Clear errors
nnoremap <leader>cc :GeneroClearErrors<CR>

" Snippet commands
nnoremap <leader>sl :GeneroSnippetList<CR>
nnoremap <leader>sh :GeneroSnippetHelp<CR>

" SVN diff markers
nnoremap <leader>sv :GeneroSVNToggle<CR>
nnoremap <leader>sr :GeneroSVNRefresh<CR>
nnoremap <leader>ss :GeneroSVNStatus<CR>

" Unified signs (compiler + SVN)
nnoremap <leader>su :GeneroUnifiedSignsToggle<CR>

" Hint navigation
nnoremap <leader>hn :GeneroNextHint<CR>
nnoremap <leader>hp :GeneroPrevHint<CR>
nnoremap <leader>hl :GeneroListHints<CR>
nnoremap <leader>hd :GeneroHintDetails<CR>
nnoremap <leader>hf :GeneroHintAutofix<CR>

" Window navigation
nnoremap <C-h> <C-w>h
nnoremap <C-j> <C-w>j
nnoremap <C-k> <C-w>k
nnoremap <C-l> <C-w>l

" Buffer navigation
nnoremap <leader>bn :bnext<CR>
nnoremap <leader>bp :bprev<CR>
nnoremap <leader>bd :bdelete<CR>

" NOTE: Do NOT remap <Esc> - it breaks arrow key detection in Vim 8.0
" Arrow keys send escape sequences like ESC[A, and remapping Esc interferes with parsing

" ============================================================================
" HELPFUL COMMANDS
" ============================================================================

command! GeneroHelp call s:show_genero_help()

function! s:show_genero_help()
  echo ''
  echo '╔════════════════════════════════════════════════════════════════╗'
  echo '║           Genero Tools Keybindings & Commands                  ║'
  echo '╚════════════════════════════════════════════════════════════════╝'
  echo ''
  echo 'COMPILATION:'
  echo '  F5              - Compile current file'
  echo '  Space+ca        - Enable autocompile on save'
  echo '  Space+cd        - Disable autocompile on save'
  echo '  Space+cc        - Clear error markers'
  echo ''
  echo 'NAVIGATION:'
  echo '  Ctrl+,          - Jump to previous error/warning'
  echo '  Ctrl+.          - Jump to next error/warning'
  echo '  Ctrl+h/j/k/l    - Navigate between windows'
  echo '  Space+bn        - Next buffer'
  echo '  Space+bp        - Previous buffer'
  echo '  Space+bd        - Delete current buffer'
  echo ''
  echo 'SNIPPETS:'
  echo '  Space+sl        - List available snippets'
  echo '  Space+sh        - Show snippet help'
  echo ''
  echo 'SVN DIFF MARKERS:'
  echo '  Space+sv        - Toggle SVN markers on/off'
  echo '  Space+sr        - Refresh SVN markers'
  echo '  Space+ss        - Show SVN status and changes'
  echo ''
  echo 'UNIFIED SIGNS:'
  echo '  Space+su        - Toggle unified signs (compiler + SVN combined)'
  echo ''
  echo 'CODE HINTS:'
  echo '  Space+hn        - Jump to next hint'
  echo '  Space+hp        - Jump to previous hint'
  echo '  Space+hl        - List all hints'
  echo '  Space+hd        - Show hint details'
  echo '  Space+hf        - Apply auto-fix for hint'
  echo ''
  echo 'AUTOCOMPLETE:'
  echo '  Ctrl+N          - Trigger code completion (insert mode)'
  echo ''
  echo 'COMMENTING:'
  echo '  gcc             - Toggle comment on line'
  echo '  gbc             - Toggle block comment'
  echo '  gc              - Toggle comment (visual mode)'
  echo '  gb              - Toggle block comment (visual mode)'
  echo ''
  echo 'COMMANDS:'
  echo '  :GeneroCompile              - Compile current file'
  echo '  :GeneroAutocompileEnable    - Enable autocompile on save'
  echo '  :GeneroAutocompileDisable   - Disable autocompile on save'
  echo '  :GeneroAutocompileStatus    - Show autocompile status'
  echo '  :GeneroClearErrors          - Clear error markers'
  echo '  :GeneroNextError            - Jump to next error'
  echo '  :GeneroPrevError            - Jump to previous error'
  echo '  :GeneroFirstError           - Jump to first error'
  echo '  :GeneroLastError            - Jump to last error'
  echo '  :GeneroLookup               - Lookup function definition'
  echo '  :GeneroListFunctions        - List functions in file'
  echo '  :GeneroListModuleFiles      - List files in module'
  echo '  :GeneroFunctionSignature    - Get function signature'
  echo '  :GeneroFileMetadata         - Get file metadata'
  echo '  :GeneroSnippetList          - List all available snippets'
  echo '  :GeneroSnippetHelp          - Show snippet documentation'
  echo '  :GeneroDebugStream          - Start debug streaming'
  echo '  :GeneroDebugStreamStop      - Stop debug streaming'
  echo '  :GeneroDebugStreamToggle    - Toggle debug stream on/off'
  echo '  :GeneroDebugStreamSelect    - Select different debug file'
  echo '  :GeneroDebugStreamClear     - Clear debug stream content'
  echo '  :GeneroDebugStreamStatus    - Show debug stream status'
  echo '  :GeneroNextHint             - Jump to next hint'
  echo '  :GeneroPrevHint             - Jump to previous hint'
  echo '  :GeneroListHints            - List all hints in file'
  echo '  :GeneroHintDetails          - Show hint details'
  echo '  :GeneroHintAutofix          - Apply auto-fix for hint'
  echo '  :GeneroHintHelp             - Show hint documentation'
  echo '  :GeneroClearHintCache       - Clear all cached hints'
  echo '  :GeneroSVNRefresh           - Manually refresh SVN markers'
  echo '  :GeneroSVNToggle            - Toggle SVN markers on/off'
  echo '  :GeneroSVNStatus            - Show SVN status and changes'
  echo '  :GeneroSVNCacheStats        - Show SVN cache statistics'
  echo '  :GeneroSVNCacheClear        - Clear SVN cache'
  echo '  :GeneroUnifiedSignsEnable   - Enable unified sign column'
  echo '  :GeneroUnifiedSignsDisable  - Disable unified sign column'
  echo '  :GeneroUnifiedSignsToggle   - Toggle unified sign column'
  echo '  :GeneroUnifiedSignsStatus   - Show unified signs status'
  echo '  :GeneroClearCache           - Clear result cache'
  echo '  :GeneroCompleteEnable       - Enable autocomplete'
  echo '  :GeneroCompleteDisable      - Disable autocomplete'
  echo '  :GeneroConfigShow           - Show current configuration'
  echo '  :GeneroHelp                 - Show this help'
  echo ''
  echo 'TIPS:'
  echo '  • Press Space to see available keybindings (Neovim only)'
  echo '  • Use Ctrl+h/j/k/l to navigate between split windows'
  echo '  • Autocompile is enabled by default (500ms delay)'
  echo '  • Errors appear in the sign column and quickfix list'
  echo '  • Code hints provide real-time code quality analysis'
  echo '  • SVN markers show added/modified/deleted lines'
  echo '  • Unified signs combine compiler and SVN markers in one column'
  echo ''
endfunction

" Show help on startup if no files are opened
autocmd VimEnter * if argc() == 0 | call s:show_genero_help() | endif

" ============================================================================
" AUTOCMDS
" ============================================================================

" Highlight on yank (Neovim only)
if has('nvim')
  autocmd TextYankPost * silent! lua vim.highlight.on_yank({higroup='IncSearch', timeout=200})
endif

" Auto-resize splits when window is resized
autocmd VimResized * wincmd =
